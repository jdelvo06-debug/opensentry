# ============================================================================
# OPENSENTRY — Environment Variables
# ============================================================================
# Copy this file to .env and adjust for your deployment.
#
#   cp .env.example .env
#
# All values below are the defaults used when the variable is not set.
# ============================================================================

# --- Ports ---
# Which host ports to bind (only relevant in docker-compose)
BACKEND_PORT=8000
FRONTEND_PORT=80

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# In dev, Vite runs on localhost:5173.  In prod, set this to your real domain.
OPENSENTRY_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://localhost

# --- Rate Limiting ---
# Max HTTP requests per IP per 60-second window
OPENSENTRY_HTTP_RATE_LIMIT=60

# Max WebSocket messages per connection per second
OPENSENTRY_WS_MSG_RATE_LIMIT=30

# --- WebSocket Limits ---
# Max concurrent WebSocket game sessions
OPENSENTRY_MAX_WS_CONNECTIONS=10

# Max inbound WebSocket message size in bytes (8 KB default)
OPENSENTRY_MAX_WS_MESSAGE_BYTES=8192

# --- Debug ---
# Set to "true" for verbose logging (never use in production)
OPENSENTRY_DEBUG=false
